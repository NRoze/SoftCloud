{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "KeyVault": {
    "Uri": "https://kv-your-app-prod.vault.azure.net/"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Placeholder_Will_Be_Overridden",
    "ApplicationInsights": "Placeholder_Will_Be_Overridden"
  },
  "Security": {
    "Jwt": {
      "Issuer": "https://your-auth-provider.com",
      "Audience": "your-api-audience"
    }
  },
  "HealthChecks": {
    "EvaluationTimeInSeconds": 30,
    "MinimumSecondsBetweenChecks": 1
  }
}